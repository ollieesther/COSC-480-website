<!DOCTYPE html>
<html lang="eng">
<head>
  <title>Login</title>
  <style>
    @import url('https://fonts.cdnfonts.com/css/orange-juice');
    body {
      text-align: center;
      background: linear-gradient(180deg, #dff7ff 0%, #eefeea 100%);
      font-family: 'Orange Juice', cursive;
      color: #2d8f63;
      min-height: 100vh;
      margin: 0;
    }
    .form-box {
      border: 2px solid #7ad6a5;
      background-color: rgba(255,255,255,.95);
      width: 320px;
      padding: 24px;
      margin: 90px auto 20px;
      border-radius: 24px;
    }
    input {
      padding: 12px 16px;
      margin: 8px 0 16px;
      border: 1px solid #90d3ae;
      border-radius: 12px;
      box-sizing: border-box;
      width: 100%;
    }
    button {
      margin-top: 20px;
      border: none;
      background: #49b675;
      color: white;
      padding: 11px 16px;
      border-radius: 999px;
      cursor: pointer;
      font-family: Arial, sans-serif;
    }
    p, b { color: #2d8f63; }
    a { color: #5b7ce2; }
  </style>
</head>
<body>
  <div class="form-box">
    <div style="font-size:4rem;">🌱</div>
    <h1>Login</h1>
    <p>Enter your account to access your plant and your garden bank.</p>
    <form>
      <div class="container">
        <label><b>Username</b></label>
        <input type="text" placeholder="Enter Username" name="username" id="username" required>
        <label><b>Password</b></label>
        <input type="password" placeholder="Enter Password" name="password" id="password" required>
      </div>
      <button type="submit" id="loginBtn">Login</button>
    </form>
    <p id='msg'><i>Login</i></p>
    <p><a href="/signup">Need an account?</a></p>
  </div>
  <script src="/loginScript.js"></script>
</body>
</html>
